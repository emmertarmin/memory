{
  "name": "@emmertarmin/memory",
  "version": "0.1.2",
  "description": "AI-powered memory and context management for LLM applications",
  "homepage": "https://github.com/emmertarmin/memory#readme",
  "bugs": {
    "url": "https://github.com/emmertarmin/memory/issues"
  },
  "license": "MIT",
  "author": "Armin Emmert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmertarmin/memory.git"
  },
  "bin": {
    "memory": "dist/index.js"
  },
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "bun test tests/*.test.ts",
    "tsc": "tsc --noEmit",
    "prebuild": "bun -e \"import p from './package.json' with {type:'json'}; await Bun.write('src/version.ts', 'export const VERSION = \\\"' + p.version + '\\\";\\n')\"",
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "bun-types": "^1.3.10",
    "undici-types": "^7.18.2"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18"
  }
}
